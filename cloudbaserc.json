{
  "envId": "lyzjkj-top-7g2o2uud420b1470",
  "version": "2.0",
  "framework": {
    "name": "lyzjkj-website",
    "plugins": {
      "hosting": {
        "use": "@cloudbase/framework-plugin-hosting",
        "inputs": {
          "outputPath": "./",
          "cloudPath": "/lyzjkj",
          "ignore": [
            "node_modules",
            ".git",
            "cloudbaserc.json",
            "package.json",
            "package-lock.json",
            "cloudfunctions"
          ]
        }
      },
      "function": {
        "use": "@cloudbase/framework-plugin-function",
        "inputs": {
          "functionRootPath": "cloudfunctions",
          "functions": [
            {
              "name": "contact-api",
              "timeout": 10,
              "runtime": "Nodejs16.13",
              "handler": "index.main"
            }
          ]
        }
      }
    }
  }
}
